# LaunchPad env (Node backend)
PORT=8000
LAUNCHPAD_LOCAL_MOCK=false

# Phase 1 — Apify (required for POST /launchpad/run — live actors only, no stub market data)
APIFY_API_TOKEN=
# Per-actor waitForFinish cap (seconds). Lower = faster runs (30–300). Default applied in code is 90 if unset.
APIFY_WAIT_FOR_FINISH_SEC=90
# Reddit fallback queries when a search returns no rows (1–4). Default 2.
# LAUNCHPAD_REDDIT_ATTEMPTS=2
# Gap before second TechCrunch category when both run (ms). Default 800.
# LAUNCHPAD_TECHCRUNCH_GAP_MS=800
# Optional dataset polling after Apify returns (ms). Defaults: first 1000, retry 800.
# LAUNCHPAD_DATASET_POLL_MS_FIRST=1000
# LAUNCHPAD_DATASET_POLL_MS_RETRY=800

# Phase 2 — Minds AI (OpenAI-compatible)
MINDS_AI_API_KEY=
MINDS_AI_BASE_URL=
MINDS_AI_MODEL=gpt-4o-mini

# Phase 3 — OpenAI (narrative + optional coach)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Optional custom endpoint
OPENAI_BASE_URL=

# Phase 4 — Storyboard images use Pollinations (no key). OPENAI_API_KEY tailors panel copy.

# Optional — merge extra Apify actor defs (JSON array); see README / VibeStart config path
EXTRA_APIFY_ACTORS_JSON=

# Apify LaunchPad tuning (memory / billing)
# LAUNCHPAD_USE_PRODUCTHUNT=1          # Opt-in Product Hunt (off by default — avoids “actor not rented” after trial)
# LAUNCHPAD_SKIP_TECHCRUNCH=1          # Skip all TechCrunch legs (big speed win)
# LAUNCHPAD_SKIP_WEBSITE_CRAWL=1       # Company URL mode only — skips Apify Website Content Crawler (faster; less page text)
# LAUNCHPAD_TECHCRUNCH_BOTH=1          # Run AI + Startups categories (default: AI only to reduce 8192MB memory hits)
# APIFY_TECHCRUNCH_MAX_POSTS=12        # Per-category post cap (raised via env if your plan allows)

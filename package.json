{
  "name": "launchpad-v2-mvp",
  "private": true,
  "version": "0.2.0",
  "scripts": {
    "install:all": "npm install && npm --prefix frontend install",
    "dev:backend": "nodemon --watch server --ext js,json server/index.js",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev": "npx concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "demo:seed": "node scripts/seed-data.mjs",
    "demo:clear": "node scripts/clear-data.mjs"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "cheerio": "^1.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "nodemon": "^3.1.10"
  }
}
